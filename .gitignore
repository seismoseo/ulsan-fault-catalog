# ==========================================================================
# Ulsan Fault catalog — version control tracks CODE + DOCS + small METADATA.
# Waveforms (~7 TB) and regenerable outputs are deliberately NOT tracked.
# Restructured 2026-07 into src/ (packages) + analysis/ + detection_test/ + data/.
# ==========================================================================

# ---- Raw waveform data (TBs) — networks + the data/ symlink layer ----
/NS/
/NS_100hz/
/GJ/
KS_KG/continuous/
/data/waveforms/

# ---- Canonical output root going forward ----
/runs/

# ---- Oversized / exploratory root notebooks ----
/01.PhaseNet_detection_test.ipynb
/02.Multi-station_detection.ipynb
notebooks/01.PhaseNet_detection_test.ipynb

# ---- Third-party / tutorial material (large .h5, FMF package) ----
/tuto_material/

# ---- Pipeline data products (regenerable), any location ----
**/picks/
**/pyocto/
**/vel_model

# ---- ufpipe generated model scaffolds (recreated by build_original_tree.py) ----
KS_KG/models/

# ---- HYPOINVERSE outputs (keep *.crh / *.sh / *.sta control inputs; drop big outputs) ----
#      HypoInv control data stays under KS_KG/HypoInv/ ; its analysis code moved to analysis/hypoinv/.
KS_KG/HypoInv/**/*.prt
KS_KG/HypoInv/**/*.arc
KS_KG/HypoInv/**/*.sum
**/*.phs
**/event_waveforms/
**/event_waveforms_*/
**/filtered_waveforms/
**/wf_similarity_cache*/
**/wf_similarity_*figs/

# ---- HypoInv working data (notebooks, catalogs, map html, logs, drivers) ----
KS_KG/HypoInv/**/*.ipynb
KS_KG/HypoInv/**/*.csv
KS_KG/HypoInv/**/*.html
KS_KG/HypoInv/UF*.sh
KS_KG/HypoInv/STA/hypoinverse/
KS_KG/HypoInv/logs/
KS_KG/HypoInv/figs/
KS_KG/HypoInv/archive/
KS_KG/detection_location/

# ---- analysis/ generated notebooks + logs (builders are tracked; their output notebooks are not) ----
analysis/**/*.ipynb
analysis/**/*.log
analysis/**/logs/
analysis/local_magnitudes/responses/master/     # master StationXML copied from external (142 MB)

# ---- detection_test/ pipeline data products (picks/catalogs/SAC stores/generated notebooks) ----
detection_test/picks/
detection_test/catalogs/
detection_test/cache/
detection_test/logs/
detection_test/reloc_*_uf*/event_sac/
detection_test/reloc_*_uf*/merged_archive/
detection_test/reloc_*_uf*/results/           # symlinks into the external runs/ tree
detection_test/**/*.ipynb

# ---- Jupyter / Python noise ----
**/.ipynb_checkpoints/
__pycache__/
*.py[cod]
.DS_Store
.virtual_documents/

# ---- editable-install / build artifacts ----
*.egg-info/
build/

# ---- backup / marker cruft ----
*.pre_*_bak
**/.nb*_done
**/.nb*_exec.log
*.cpt
gmt.history
**/gmt.history
